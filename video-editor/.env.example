# Copy this file to ".env" and fill in your keys.

# OpenAI — used for Whisper speech-to-text (transcription with timestamps).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic — used for the "editing brain": turning your instructions + the
# transcript + keyframe descriptions into a cut list, plus subtitle translation.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
PORT=8787
# Max upload size in MB
MAX_UPLOAD_MB=500
# Claude model for editing decisions / translation / vision
CLAUDE_MODEL=claude-sonnet-4-6
# Whisper model
WHISPER_MODEL=whisper-1
